# ===== Server =====
PORT=4000
NODE_ENV=development
# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173

# ===== Database (MongoDB Atlas) =====
# Atlas: Cluster → Connect → Drivers → copy the connection string.
# Format: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/hr_system?retryWrites=true&w=majority
MONGODB_URI=

# ===== Auth (self-managed JWT) =====
# Random secret used to sign access tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
# Access-token lifetime in seconds (default 7 days).
JWT_EXPIRES_IN=604800

# ===== Uploads =====
# Max attachment size in bytes (default 25 MB). Files are stored in MongoDB GridFS.
MAX_UPLOAD_BYTES=26214400

# Public URL of the frontend, used to build approval links in emails.
APP_BASE_URL=http://localhost:5173

# ===== Email (optional; SMTP) =====
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="HR System <no-reply@example.com>"
