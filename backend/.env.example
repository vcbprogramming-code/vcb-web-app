# ===== Server =====
PORT=4000
NODE_ENV=development
# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173

# ===== Database (direct Postgres connection) =====
# Supabase: Project Settings → Database → Connection string → URI
# Format: postgresql://USER:PASSWORD@HOST:5432/postgres
DATABASE_URL=

# ===== Auth (self-managed JWT) =====
# Random secret used to sign access tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
# Access-token lifetime in seconds (default 7 days).
JWT_EXPIRES_IN=604800
