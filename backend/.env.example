# ===== Server =====
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ===== Database (Supabase Postgres) =====
# Project Settings → Database → Connection string → URI (Session/Transaction pooler)
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-0-xxx.pooler.supabase.com:5432/postgres

# ===== Auth (self-managed JWT) =====
JWT_SECRET=
JWT_EXPIRES_IN=604800

# ===== Uploads =====
MAX_UPLOAD_BYTES=26214400

# ===== File storage (Supabase Storage via S3 protocol) =====
# Project Settings → Storage → S3 Connection
S3_ENDPOINT=https://xxxxx.storage.supabase.co/storage/v1/s3
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=documents

# ===== Public base URL of the frontend (for approval email links) =====
APP_BASE_URL=http://localhost:5173

# ===== Email (optional; Brevo / any SMTP) =====
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=
