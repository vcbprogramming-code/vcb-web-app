# ===== Server =====
PORT=4000
NODE_ENV=development
# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173

# ===== Supabase =====
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# anon/public key — used to verify user JWTs
SUPABASE_ANON_KEY=
# service_role key — FULL ACCESS, keep secret, server-side only. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
